{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ollama": {
    "BaseUrl": "http://localhost:11434/",
    "Model": "llama3.2:3b"
  },
  "OpenMeteo": {
    "BaseUrl": "https://api.open-meteo.com"
  },
  "Assistant": {
    "SystemPrompt": "You are GardenAI Helper for a Raspberry Pi based garden automation system. You prioritize practical, safe, actionable advice about plant care, seeding, watering, and sensor-driven troubleshooting.",
    "MaxHistoryMessages": 30
  },
  "GardenAdvisor": {
    "RegionName": "Copenhagen, Denmark",
    "Latitude": 55.6761,
    "Longitude": 12.5683,
    "Timezone": "Europe/Copenhagen",
    "AdviceSummaryTopic": "GardenAI/garden/advice/summary",
    "PotInsightTopicPrefix": "GardenAI/garden/pots",
    "PlannerResponseTopic": "GardenAI/garden/planner/response",
    "PlannerHistoryTopic": "GardenAI/garden/planner/history",
    "PlannerMaxIterations": 2,
    "EnableScheduledAdvice": true
  },
  "PotIdentityMap": {
    "PotNumberToId": {
      "1": "11111111-1111-1111-1111-111111111111",
      "2": "22222222-2222-2222-2222-222222222222",
      "3": "33333333-3333-3333-3333-333333333333",
      "4": "44444444-4444-4444-4444-444444444444",
      "5": "55555555-5555-5555-5555-555555555555",
      "6": "66666666-6666-6666-6666-666666666666"
    }
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "ClientId": "GardenAI-api",
    "Username": "",
    "Password": "",
    "KeepAliveSeconds": 60,
    "ReconnectDelaySeconds": 5,
    "ConnectionTimeoutSeconds": 10,
    "PublishMockReadings": false,
    "MockPublishIntervalSeconds": 10,
    "Zigbee2MqttTopicPrefix": "zigbee2mqtt",
    "SensorTopicMappings": {
      "pot-1": "00000000-0000-0000-0000-000000000001",
      "pot-2": "00000000-0000-0000-0000-000000000002",
      "pot-3": "00000000-0000-0000-0000-000000000003",
      "pot-4": "00000000-0000-0000-0000-000000000004",
      "pot-5": "00000000-0000-0000-0000-000000000005",
      "pot-6": "00000000-0000-0000-0000-000000000006"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=GardenAI;Username=ha_user;Password="
  }
}
