### ── Pot Configuration & Room Management ──────────────────────────────────────

GET http://localhost:5064/api/garden/rooms
Accept: application/json

###

# Get configuration for a pot (replace with actual pot ID)
GET http://localhost:5064/api/garden/pots/00000000-0000-0000-0000-000000000001/configuration
Accept: application/json

###

# Save/update pot configuration with room and seed assignments
POST http://localhost:5064/api/garden/pots/00000000-0000-0000-0000-000000000001/configuration
Content-Type: application/json

{
  "roomAreaId": "living_room",
  "roomName": "Living Room",
  "seeds": [
    {
      "plantName": "Tomato",
      "seedName": "Moneymaker",
      "plantedDate": "2026-04-01T00:00:00Z",
      "expectedHarvestDate": "2026-06-15T00:00:00Z",
      "status": "growing",
      "notes": "Companion planting: basil"
    }
  ]
}


### ── Seed Status & Harvest Readiness ──────────────────────────────────────

# Update a seed's lifecycle status
POST http://localhost:5064/api/garden/pots/00000000-0000-0000-0000-000000000001/seeds/11111111-1111-1111-1111-111111111111/status
Content-Type: application/json

{
  "newStatus": "mature"
}

###

# Get harvest readiness for all seeds (optional: filter by status)
GET http://localhost:5064/api/garden/seeds/harvest-readiness
Accept: application/json

###

# Get harvest readiness filtered by status
GET http://localhost:5064/api/garden/seeds/harvest-readiness?filterByStatus=growing
Accept: application/json

###

# Get full dashboard aggregation (all rooms, pots, seeds with health statuses)
GET http://localhost:5064/api/garden/pots/dashboard
Accept: application/json

###

# Get room-specific summary (Living Room)
GET http://localhost:5064/api/garden/rooms/living_room/summary
Accept: application/json

###

# Get room-specific summary (Kitchen)
GET http://localhost:5064/api/garden/rooms/kitchen/summary
Accept: application/json


### ── Garden Planner Chat (AI + auto-save) ───────────────────────────────────

# Ask a question – no action executed
POST http://localhost:5064/api/garden/planner/chat
Content-Type: application/json

{
  "message": "What would be a good plant to put in pot 3 given the current moisture levels?"
}

###

# Planting intent – triggers SavePotConfigurationCommand automatically
POST http://localhost:5064/api/garden/planner/chat
Content-Type: application/json

{
  "message": "I'm planting basil and tomatoes today – basil in pot 1 in the living room, tomatoes in pot 2 on the balcony."
}

###

# Multi-pot planting intent
POST http://localhost:5064/api/garden/planner/chat
Content-Type: application/json

{
  "message": "Set up pot 4 with cucumber Marketmore in the greenhouse, and pot 5 with lettuce Little Gem also in the greenhouse."
}


### ── Garden Planner Kestrel Functions ───────────────────────────────────────

# List all pot statuses in one response
GET http://localhost:5064/api/garden/planner/functions/pots
Accept: application/json

###

# Read one pot status
POST http://localhost:5064/api/garden/planner/functions/pots/status
Content-Type: application/json

{
  "potNumber": 1
}

###

# Read one pot's latest sensor readings
POST http://localhost:5064/api/garden/planner/functions/pots/sensors
Content-Type: application/json

{
  "potNumber": 3
}

###

# Save a pot configuration via planner function
POST http://localhost:5064/api/garden/planner/functions/pots/save
Content-Type: application/json

{
  "potNumber": 2,
  "plantName": "Tomato",
  "seedName": "Moneymaker",
  "roomAreaId": "balcony",
  "status": "growing",
  "plantedDate": "2026-04-05T00:00:00Z",
  "notes": "Companion with basil later"
}

###

# Update the active seed status in a pot
POST http://localhost:5064/api/garden/planner/functions/pots/update-seed-status
Content-Type: application/json

{
  "potNumber": 2,
  "newStatus": "mature"
}

###

# List available rooms
GET http://localhost:5064/api/garden/planner/functions/rooms
Accept: application/json

###

# Get room summary
GET http://localhost:5064/api/garden/planner/functions/rooms/living_room
Accept: application/json

###

# Get dashboard snapshot
GET http://localhost:5064/api/garden/planner/functions/dashboard
Accept: application/json

###

# Get harvest readiness (all)
GET http://localhost:5064/api/garden/planner/functions/harvest-readiness
Accept: application/json

###

# Get harvest readiness filtered by status
GET http://localhost:5064/api/garden/planner/functions/harvest-readiness?filterByStatus=growing
Accept: application/json

###

# Get latest generated advice
GET http://localhost:5064/api/garden/planner/functions/advice/latest
Accept: application/json

###

# Generate fresh garden advice via planner function
POST http://localhost:5064/api/garden/planner/functions/advice/generate
Content-Type: application/json

{
  "publishToMqtt": true
}

###

# Clear planner history
POST http://localhost:5064/api/garden/planner/functions/history/clear
Content-Type: application/json

{}

